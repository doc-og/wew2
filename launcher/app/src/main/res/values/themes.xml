<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose launcher: AppCompat base with no action bar, window draws edge-to-edge -->
    <style name="Theme.WewLauncher" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#0E0B1E</item>
        <item name="android:navigationBarColor">#0E0B1E</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
